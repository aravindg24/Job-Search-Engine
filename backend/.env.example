CEREBRAS_API_KEY=your_cerebras_api_key_here
# Available models: llama3.1-8b, gpt-oss-120b, qwen-3-235b-a22b-instruct-2507
CEREBRAS_MODEL=llama3.1-8b
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=jobs
EMBEDDING_MODEL=all-MiniLM-L6-v2
CORS_ORIGINS=http://localhost:5173
USE_MEMORY_QDRANT=true

# Supabase (get these from https://supabase.com/dashboard/project/<your-project>/settings/api)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key-here
